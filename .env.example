# Setu — Environment Variables Template
# Copy this to .env.local and fill in your Supabase credentials.
# NEVER commit .env.local to version control.

# ─── Supabase ────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── App ─────────────────────────────────────────────────────
VITE_APP_NAME=Setu
VITE_APP_VERSION=0.1.0
VITE_APP_ENV=development

# ─── Feature Flags ───────────────────────────────────────────
VITE_FF_DIABETES_MODULE=false
VITE_FF_TUBERCULOSIS_MODULE=false
VITE_FF_MATERNAL_MODULE=false
VITE_FF_COPD_MODULE=false
